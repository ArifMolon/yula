#!/bin/sh
set -eu

dry_run=false
if [ "${1:-}" = "--dry-run" ]; then
  dry_run=true
  shift
fi

command_name=${1:-}
spec=${2:-}
issue=${3:-}
feature=${4:-}

usage() {
  echo "usage: scripts/spec-worktree [--dry-run] bootstrap|inspect|cleanup <spec-name>" >&2
  echo "       scripts/spec-worktree [--dry-run] start-feature <spec-name> <issue-number> <feature-name>" >&2
  echo "       scripts/spec-worktree [--dry-run] finish-feature <spec-name> <issue-number>" >&2
  exit 2
}

[ -n "$command_name" ] && [ -n "$spec" ] || usage
case "$spec" in *[!a-z0-9-]*|'') echo "invalid spec slug: $spec" >&2; exit 2;; esac

worktree=".worktrees/spec-$spec"
spec_branch="spec/$spec"

run() {
  if [ "$dry_run" = true ]; then
    echo "+ $*"
  else
    "$@"
  fi
}

case "$command_name" in
  bootstrap)
    [ ! -e "$worktree" ] || { echo "spec worktree already exists: $worktree" >&2; exit 1; }
    run git worktree add "$worktree" -b "$spec_branch"
    run git -C "$worktree" config --worktree pnpm.store-dir "$(git rev-parse --show-toplevel)/my-docs/.local/pnpm-store"
    run git -C "$worktree" sparse-checkout set --no-cone "/*" "!/my-docs/" "!/.worktrees/" "!/.superpowers/"
    ;;
  start-feature)
    [ -n "$issue" ] && [ -n "$feature" ] || usage
    active=$(git -C "$worktree" branch --show-current 2>/dev/null || true)
    case "$active" in feature/*) echo "active feature already checked out: $active" >&2; exit 1;; esac
    run git -C "$worktree" switch -c "feature/$issue-$feature" "$spec_branch"
    ;;
  finish-feature)
    [ -n "$issue" ] || usage
    active=$(git -C "$worktree" branch --show-current)
    case "$active" in "feature/$issue-"*) ;; *) echo "issue $issue is not active" >&2; exit 1;; esac
    [ -z "$(git -C "$worktree" status --porcelain)" ] || { echo "dirty worktree blocks feature finish" >&2; exit 1; }
    run git -C "$worktree" switch "$spec_branch"
    run git -C "$worktree" merge --no-ff "$active"
    run git branch -d "$active"
    ;;
  inspect)
    git -C "$worktree" status --short --branch
    git branch --list "feature/*"
    git stash list
    ;;
  cleanup)
    if [ "$dry_run" = true ]; then
      echo "+ validate clean merged spec worktree, branches, stashes, claims, artifacts, and HITL"
      echo "+ git worktree remove $worktree"
      echo "+ git branch -d $spec_branch"
      echo "+ git worktree prune"
      exit 0
    fi
    [ -d "$worktree" ] || { echo "missing worktree: $worktree" >&2; exit 1; }
    [ -z "$(git -C "$worktree" status --porcelain)" ] || { echo "dirty worktree blocks cleanup" >&2; exit 1; }
    [ "$(git -C "$worktree" branch --show-current)" = "$spec_branch" ] || { echo "feature branch still active" >&2; exit 1; }
    [ -z "$(git branch --no-merged main --list "$spec_branch")" ] || { echo "unmerged spec branch blocks cleanup" >&2; exit 1; }
    run git worktree remove "$worktree"
    run git branch -d "$spec_branch"
    run git worktree prune
    ;;
  *) usage;;
esac
